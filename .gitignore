.DS_Store
*.pyc
__pycache__/

# Drive sync artifacts (regenerated by scripts/sync_drive.py)
raw/.sync_manifest.json
raw/_drive_staging/

# Secrets — NEVER commit
.env
*.env.local

# Jira sync data — large, regenerable from API
raw/jira/tickets.sqlite
raw/jira/tickets.sqlite-journal
raw/jira/tickets.sqlite-wal
raw/jira/tickets.sqlite-shm
raw/jira/embeddings.db
raw/jira/embeddings.db-journal
raw/jira/embeddings.db-wal
raw/jira/embeddings.db-shm
raw/jira/sync.log
raw/jira/cost.log
raw/jira/triage_review.csv
raw/jira/backfill.stdout.log
raw/jira/backfill.stderr.log
raw/jira/checkpoints/*.json

# PMS dashboard API captures — may contain customer config values
raw/pms-api/
raw/pms-default-properties/*.json

# Answer feedback captures — may contain customer/user debugging context
raw/feedback/

# Chat history — per-user runtime data, not source-controlled
raw/conversations/

# Auth store — runtime user/token data, not source-controlled
raw/auth/

# Live debug session files — contain customer config data, stored in /tmp/ by default
# but guard against accidental in-repo saves
pms_debug_*.json

# Python virtualenvs (in case user creates one in-repo)
.venv/
venv/
