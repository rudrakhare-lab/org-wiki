# .env.example — copy this to .env and fill in real values.
# .env is gitignored; .env.example is committed as a template.
#
# To load into shell:
#   set -a && source .env && set +a
# Or load individual vars selectively:
#   export PMS_TOKEN_IN=$(grep '^PMS_TOKEN_IN=' .env | cut -d'=' -f2-)
#   export PMS_COOKIE_IN=$(grep '^PMS_COOKIE_IN=' .env | cut -d'=' -f2-)
#   export PMS_COOKIE_COM=$(grep '^PMS_COOKIE_COM=' .env | cut -d'=' -f2-)

# ----------------------------------------------------------------------
# Jira Cloud credentials
# ----------------------------------------------------------------------
JIRA_BASE_URL=https://moveinsync.atlassian.net
JIRA_EMAIL=your.email@moveinsync.com
JIRA_API_TOKEN=paste-your-atlassian-api-token-here

# ----------------------------------------------------------------------
# PMS Live Config — .com server (global/international clients)
#
# .com uses cookie-based auth — no JWT bearer token required.
# To refresh:
#   1. Open https://cmsapp.moveinsync.com in Chrome
#   2. DevTools → Network → click any /propmanagement/ request → Headers tab
#   3. Copy the full "cookie" header value → paste as PMS_COOKIE_COM
#   (PMS_TOKEN_COM can be left empty for .com)
# ----------------------------------------------------------------------
PMS_TOKEN_COM=
PMS_COOKIE_COM=paste-full-cookie-string-here

# ----------------------------------------------------------------------
# PMS Live Config — .in server (India-region clients)
#
# .in requires BOTH a JWT bearer token AND a cookie.
# To refresh:
#   1. Open https://cmsapp.moveinsync.in in Chrome
#   2. DevTools → Network → click any /propmanagement/ request → Headers tab
#   3. Copy "authorization" header value WITHOUT the "Bearer " prefix → PMS_TOKEN_IN
#   4. Copy full "cookie" header value → PMS_COOKIE_IN
# ----------------------------------------------------------------------
PMS_TOKEN_IN=paste-jwt-token-here-without-Bearer-prefix
PMS_COOKIE_IN=paste-full-cookie-string-here

# ----------------------------------------------------------------------
# PMS fallback — used if server-specific vars above are not set
# Leave blank once you have server-specific vars configured.
# ----------------------------------------------------------------------
PMS_TOKEN=
PMS_COOKIE=

# ----------------------------------------------------------------------
# Optional — Anthropic API
# ----------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...

# G24: model id used by the deep-search tool-use loop (backend/providers/deep_query.py)
# Default: claude-sonnet-4-6. Override for A/B testing or to swap families.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Cheaper model used by the conversation compactor (backend/conversation_compactor.py).
# Default: claude-haiku-4-5. ~200 output tokens per call.
# ANTHROPIC_COMPACTOR_MODEL=claude-haiku-4-5

# G10: max rounds in the tool-use loop before forced synthesis.
# Default: 12 (bumped from 8 to cover deep PMS-debug queries). Tune in prod
# without redeploy. Needs eval validation against the parity question set.
# MAX_TOOL_ROUNDS=12
